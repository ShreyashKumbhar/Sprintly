DB_USER=postgres
DB_PASSWORD=postgres

# Backend (EC2) -> RDS connection
SPRING_DATASOURCE_URL=jdbc:postgresql://<RDS-ENDPOINT>:5432/sprintly
SPRING_DATASOURCE_USERNAME=<RDS-USERNAME>
SPRING_DATASOURCE_PASSWORD=<RDS-PASSWORD>

# JWT config
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRATION=86400000

# Frontend (S3/CloudFront) allowed by backend CORS (comma-separated)
CORS_ALLOWED_ORIGINS=https://<YOUR-FRONTEND-DOMAIN>
