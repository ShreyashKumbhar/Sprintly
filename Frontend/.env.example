# Frontend API origin used by `src/api/client.js`.
# For AWS deployment, set this to your EC2 public API URL or ALB DNS.
# Example: VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# Optional: override Vite dev proxy target (local development only).
# Example: VITE_DEV_PROXY_TARGET=http://localhost:8080
VITE_DEV_PROXY_TARGET=
